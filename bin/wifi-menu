#!/bin/bash

chosen=$(nmcli -t -f SSID,SIGNAL,SECURITY device wifi list --rescan yes |
  awk -F: '!seen[$1]++ && $1 != "" {print $1 "  " $2 "%  " $3}' |
  rofi -dmenu -p "Wi-Fi")

[ -z "$chosen" ] && exit 0

ssid=$(echo "$chosen" | awk '{print $1}')

if nmcli connection show "$ssid" >/dev/null 2>&1; then
  action=$(printf "Conectar\nEsquecer e digitar senha novamente" | rofi -dmenu -p "$ssid")

  if [ "$action" = "Esquecer e digitar senha novamente" ]; then
    nmcli connection delete "$ssid"
    pass=$(rofi -dmenu -password -p "Senha de $ssid")
    [ -z "$pass" ] && exit 0
    nmcli device wifi connect "$ssid" password "$pass"
  else
    nmcli connection up "$ssid"
  fi
else
  pass=$(rofi -dmenu -password -p "Senha de $ssid")
  [ -z "$pass" ] && exit 0
  nmcli device wifi connect "$ssid" password "$pass"
fi
